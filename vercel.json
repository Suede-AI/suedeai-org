{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/home/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/guide/",
      "destination": "/book/",
      "permanent": true
    },
    {
      "source": "/ai/",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
