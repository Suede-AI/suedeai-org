{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/",
      "destination": "https://www.suedeai.xyz/",
      "permanent": false
    },
    {
      "source": "/:path*",
      "destination": "https://www.suedeai.xyz/:path*",
      "permanent": false
    },
    {
      "source": "/:path*/",
      "destination": "https://www.suedeai.xyz/:path*/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
